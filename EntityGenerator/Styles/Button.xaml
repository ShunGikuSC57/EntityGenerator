<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTemplate x:Key="BlueButton" TargetType="Button">
        <Border Name="Border" BorderThickness="1" BorderBrush="#0000FF" Background="#0000FF" CornerRadius="3">
            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#00008B"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#00008B"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#191970"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#00008B"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
    <ControlTemplate x:Key="GreenButton" TargetType="Button">
        <Border Name="Border" BorderThickness="1" BorderBrush="#008000" Background="#008000" CornerRadius="3">
            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#006400"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#006400"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#556B2F"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#556B2F"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
    <ControlTemplate x:Key="OrangeButton" TargetType="Button">
        <Border Name="Border" BorderThickness="1" BorderBrush="#FF8C00" Background="#FF8C00" CornerRadius="3">
            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#FF4500"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#FF4500"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#A52A2A"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#A52A2A"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
    <ControlTemplate x:Key="GrayButton" TargetType="Button">
        <Border Name="Border" BorderThickness="1" BorderBrush="#444444" Background="#444444" CornerRadius="3">
            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#333333"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#333333"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#2F4F4F"/>
                <Setter TargetName="Border" Property="BorderBrush" Value="#2F4F4F"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>