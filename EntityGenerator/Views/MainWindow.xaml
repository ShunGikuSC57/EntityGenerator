<Window x:Class="EntityGenerator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EntityGenerator"
        xmlns:vm="clr-namespace:EntityGenerator.ViewModels"
        xmlns:uc="clr-namespace:EntityGenerator.UserControls"
        mc:Ignorable="d"
        Title="Entity生成ツール" Height="868" Width="1024" Background="#F5F5F5" FontSize="20" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="0.4*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="生成対象">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="1" GroupName="GenerateTarget" VerticalContentAlignment="Center" Content="プロパティ" IsChecked="{Binding IsGenerateProperty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton Grid.Column="3" GroupName="GenerateTarget" VerticalContentAlignment="Center" Content="ViewModel" IsChecked="{Binding IsGenerateViewModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton Grid.Column="5" GroupName="GenerateTarget" VerticalContentAlignment="Center" Content="命名規則に従って変換する" IsChecked="{Binding IsGenerateConverted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="ViewModel実装方式" IsEnabled="{Binding IsGenerateViewModel}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                    <RadioButton GroupName="ViewModelStyle" VerticalContentAlignment="Center" Content="ObservableProperty" IsChecked="{Binding IsViewModelStyleObservableProperty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton GroupName="ViewModelStyle" VerticalContentAlignment="Center" Content="SetProperty" IsChecked="{Binding IsViewModelStyleSetProperty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </GroupBox>
        </Grid>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.75*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="0.25*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Grid.Column="0" Header="命名規則">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                    <RadioButton GroupName="NamingConvention" VerticalContentAlignment="Center" Content="パスカルケース" IsChecked="{Binding IsNamingPascal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton GroupName="NamingConvention" VerticalContentAlignment="Center" Content="キャメルケース" IsChecked="{Binding IsNamingCamel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton GroupName="NamingConvention" VerticalContentAlignment="Center" Content="大文字" IsChecked="{Binding IsNamingUpper, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton GroupName="NamingConvention" VerticalContentAlignment="Center" Content="小文字" IsChecked="{Binding IsNamingLower, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton GroupName="NamingConvention" VerticalContentAlignment="Center" Content="物理名のまま" IsChecked="{Binding IsNamingAsIs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="入力元">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                    <RadioButton GroupName="InputSource" VerticalContentAlignment="Center" Content="EXCEL" IsChecked="{Binding IsSourceExcel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton GroupName="InputSource" VerticalContentAlignment="Center" Content="直接入力" IsChecked="{Binding IsSourceInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </GroupBox>
        </Grid>
        <GroupBox Grid.Row="2" IsEnabled="{Binding IsSourceExcel}">
            <GroupBox.Header>
                <TextBlock Foreground="#008000" Text="EXCEL"/>
            </GroupBox.Header>
            <Grid Margin="10,5,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ExcelFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotFocus="TextBox_GotFocus"/>
                    <Button Grid.Column="2" Template="{StaticResource GreenButton}" Command="{Binding SelectExcelCommand}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Margin="0,5,3,5" Source="/Images/File.png"/>
                                <TextBlock Text="選択"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="350"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="読込シート名"/>
                        <TextBox Grid.Column="2" Text="{Binding ReadSheetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotFocus="TextBox_GotFocus"/>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="読込対象"/>
                        <uc:NumericUpDown Grid.Column="2" MinValue="1" MaxValue="999" Value="{Binding ReadRowFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="4" Text="～"/>
                        <uc:NumericUpDown Grid.Column="6" MinValue="1" MaxValue="999" Value="{Binding ReadRowTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="8" Text="行目まで"/>
                    </Grid>
                </Grid>
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition MinWidth="15"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="論理名"/>
                        <uc:NumericUpDown Grid.Column="2" MinValue="1" MaxValue="999" Value="{Binding LogicalNameColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="4" Text="列"/>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="物理名"/>
                        <uc:NumericUpDown Grid.Column="2" MinValue="0" MaxValue="999" Value="{Binding PhysicsNameColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="4" Text="列"/>
                    </Grid>
                    <Grid Grid.Column="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="データ型"/>
                        <uc:NumericUpDown Grid.Column="2" MinValue="0" MaxValue="999" Value="{Binding DataTypeColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="4" Text="列"/>
                    </Grid>
                    <Grid Grid.Column="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Null制約"/>
                        <uc:NumericUpDown Grid.Column="2" MinValue="0" MaxValue="999" Value="{Binding NullableColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="4" Text="列"/>
                    </Grid>
                    <Button Grid.Column="8" Template="{StaticResource GreenButton}" Command="{Binding SaveSpecCommand}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Margin="0,5,3,5" Source="/Images/Excel.png"/>
                                <TextBlock Text="定義書出力"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </Grid>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="3" Header="出力方法">
            <Grid Margin="10,5,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition MinWidth="15"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal">
                    <RadioButton GroupName="OutputMethod" VerticalContentAlignment="Center" Content="画面" IsChecked="{Binding IsScreenOutput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <RadioButton IsEnabled="{Binding IsFileOutputEnabled}" GroupName="OutputMethod" VerticalContentAlignment="Center" Content="ファイル" IsChecked="{Binding IsFileOutput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Grid Grid.Column="1" IsEnabled="{Binding IsFileOutput}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="名前空間"/>
                    <TextBox Grid.Column="2" InputMethod.IsInputMethodEnabled="False" Text="{Binding Namespace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotFocus="TextBox_GotFocus"/>
                    <TextBlock Grid.Column="4" Text="クラス名"/>
                    <TextBox Grid.Column="6" InputMethod.IsInputMethodEnabled="False" Text="{Binding ClassName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" GotFocus="TextBox_GotFocus"/>
                </Grid>
                <Button Grid.Column="3" Template="{StaticResource BlueButton}" Command="{Binding OutputEntityCommand}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <Image Margin="0,5,3,5" Source="/Images/CS.png"/>
                            <TextBlock Text="出力"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </GroupBox>
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="0.7*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid Grid.Column="0" IsEnabled="{Binding IsSourceInput}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="10,0,0,0" Text="入力内容"/>
                <TextBox Grid.Row="1"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBox_GotFocus"/>
            </Grid>
            <Grid Grid.Column="2" IsEnabled="{Binding IsScreenOutput}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="10,0,0,0" Text="生成コード"/>
                <TextBox Grid.Row="1"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="#F5F5F5"
                         FontSize="14"
                         Text="{Binding OutputText, Mode=OneWay}"/>
            </Grid>
        </Grid>
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition MinWidth="100"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Template="{StaticResource OrangeButton}" Command="{Binding ShowDataTypesCommand}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Image Margin="0,5,3,5" Source="/Images/JSON.png"/>
                        <TextBlock Text="データ型定義表示"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Grid.Column="2" Template="{StaticResource OrangeButton}" Command="{Binding ReloadDataTypesCommand}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Image Margin="0,5,3,5" Source="/Images/JSON.png"/>
                        <TextBlock Text="データ型定義再読込"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button Grid.Column="4" Template="{StaticResource GrayButton}" Command="{Binding ExitCommand}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <Image Margin="0,5,3,5" Source="/Images/Exit.png"/>
                        <TextBlock Text="終了"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</Window>
